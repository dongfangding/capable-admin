<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ddf.boot.capableadmin.infra.mapper.SysUserDeptMapper">
	<insert id="batchInsert">
		insert into sys_user_dept (user_id, dept_id)
		values
		<foreach collection="list" item="item">
			(#{item.userId}, #{item.deptId})
		</foreach>
	</insert>


	<select id="selectDeptIdsByUserIds" resultType="map">
		select user_id as userId, dept_id as relationId
		from sys_user_dept
		where user_id in
		<foreach close=")" collection="userIds" item="userId" open="(" separator=",">
			#{userId}
		</foreach>
	</select>



	<delete id="deleteByDeptIds">
		delete from sys_user_dept
		where dept_id in
		<foreach close=")" collection="deptIds" item="deptId" open="(" separator=",">
			#{deptId}
		</foreach>
	</delete>


	<delete id="deleteByUserId">
		delete from sys_user_dept
		where user_id = #{userId}
	</delete>

	<delete id="deleteByUserIds">
		delete from sys_user_dept
		where user_id in
		<foreach close=")" collection="userIds" item="userId" open="(" separator=",">
			#{userId}
		</foreach>
	</delete>
</mapper>
